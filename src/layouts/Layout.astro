---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-gray-900 text-white">
    <!-- Barra de Navegación -->
    <header class="fixed top-0 left-0 w-full bg-gray-900 bg-opacity-80 backdrop-blur-sm z-50">
      <nav class="container mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-600">
          Intellecto
        </a>
        <div class="flex space-x-4">
          <a href="/portfolio" class="hover:text-purple-300 transition-colors">Portafolio</a>
          <a href="/blog" class="hover:text-pink-300 transition-colors">Blog</a>
          <a href="/sobre-mi" class="hover:text-teal-300 transition-colors">Sobre Mí</a>
          <a href="https://app.intellecto.com.co" target="_blank" class="hover:text-green-300 transition-colors">Inngenia</a>
        </div>
      </nav>
    </header>

    <!-- Contenido Principal -->
    <main>
      <slot />
    </main>

    <!-- Pie de Página -->
    <footer class="bg-gray-800 mt-16 py-8">
      <div class="container mx-auto px-6 text-center text-gray-400">
        <p>&copy; {new Date().getFullYear()} Intellecto. Todos los derechos reservados.</p>
        <div class="flex justify-center space-x-4 mt-4">
          <a href="#" class="hover:text-white">GitHub</a>
          <a href="#" class="hover:text-white">LinkedIn</a>
          <a href="#" class="hover:text-white">Twitter</a>
        </div>
      </div>
    </footer>
  </body>
</html>
