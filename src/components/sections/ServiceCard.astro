---
import GlassCard from '../ui/GlassCard.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  backgroundImage: string;
  delay?: string;
  isMinimal?: boolean;
}

const { title, description, href, backgroundImage, delay = "100ms", isMinimal = false } = Astro.props;
---

<div class="reveal" style={`transition-delay: ${delay};`}>
  <a href={href} class={`service-card-lux ${isMinimal ? 'is-minimal' : ''}`}>
    <div class="glass-container">
      {/* Background Glow */}
      <div class="card-glow"></div>
      
      <div class="card-content">
        <div class="icon-wrapper">
          <div class="icon-glass">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m5 9 7-7 7 7"/><path d="m19 15-7 7-7-7"/></svg>
          </div>
        </div>

        <div class="text-area">
          <h3 class="lux-title">{title}</h3>
          <p class="lux-desc">{description}</p>
        </div>

        <div class="lux-action">
          <span class="action-label">Explorar Solutions</span>
          <div class="action-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </div>
        </div>
      </div>
      
      {/* Border Highlight Effect */}
      <div class="border-highlight"></div>
    </div>
  </a>
</div>

<style>
  .service-card-lux {
    text-decoration: none;
    display: block;
    height: 100%;
    position: relative;
    border-radius: 32px;
    background: transparent;
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .glass-container {
    height: 100%;
    padding: 2.5rem;
    background: rgba(var(--color-bg-rgb), 0.4);
    backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    transition: inherit;
  }

  :global(.dark) .glass-container {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0) 100%);
    box-shadow: 
      inset 0 0 0 1px rgba(255, 255, 255, 0.05),
      0 20px 40px -20px rgba(0, 0, 0, 0.5);
  }

  .card-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(var(--color-accent-rgb), 0.15) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.8s ease;
    filter: blur(40px);
    pointer-events: none;
    z-index: 0;
  }

  .service-card-lux:hover .card-glow {
    opacity: 1;
  }

  .icon-wrapper {
    margin-bottom: 2rem;
    position: relative;
    z-index: 2;
  }

  .icon-glass {
    width: 64px;
    height: 64px;
    background: rgba(var(--color-accent-rgb), 0.1);
    border: 1px solid rgba(var(--color-accent-rgb), 0.2);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    transition: all 0.5s var(--ease-out-expo);
    position: relative;
  }

  .icon-glass::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), transparent);
    opacity: 0.5;
    pointer-events: none;
  }

  .service-card-lux:hover .icon-glass {
    transform: translateY(-5px) rotate(-10deg);
    background: var(--color-accent);
    color: white;
    box-shadow: 0 15px 30px -5px rgba(var(--color-accent-rgb), 0.5);
  }

  .text-area {
    position: relative;
    z-index: 2;
    margin-bottom: 3rem;
  }

  .lux-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 300;
    color: var(--color-text-primary);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    transition: color 0.4s ease;
  }

  .service-card-lux:hover .lux-title {
    color: var(--color-text-primary);
    font-weight: 800;
  }

  .lux-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    opacity: 0.8;
  }

  .lux-action {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    z-index: 2;
  }

  .action-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: all 0.4s ease;
  }

  .action-circle {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
    transition: all 0.5s var(--ease-out-expo);
  }

  .service-card-lux:hover .action-label {
    color: var(--color-accent);
    transform: translateX(10px);
  }

  .service-card-lux:hover .action-circle {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: white;
    transform: scale(1.1);
  }

  .border-highlight {
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    border-radius: 32px;
    background: linear-gradient(135deg, rgba(var(--color-accent-rgb), 0.3), transparent 40%) border-box;
    mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .service-card-lux:hover .border-highlight {
    opacity: 1;
  }

  .service-card-lux:hover .glass-container {
    transform: translateY(-10px);
    border-color: rgba(var(--color-accent-rgb), 0.3);
    box-shadow: 
      0 40px 60px -30px rgba(0, 0, 0, 0.5),
      inset 0 0 0 1px rgba(var(--color-accent-rgb), 0.2);
  }
</style>
