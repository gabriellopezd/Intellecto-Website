---
import Button from '../ui/Button.astro';
import GlassCard from '../ui/GlassCard.astro';
---

<section id="app-showcase" class="section showcase-container">
  <div class="container-main">
    <div class="grid-showcase">
      <!-- Content Side -->
      <div class="showcase-content reveal">
        <div class="section-tag">Proof of Concept</div>
        <h2 class="section-title" style="text-align: left; margin-bottom: 2rem;">
          Nuestro Conocimiento en <br/>
          <span class="gradient-text-lux">Desarrollo Vivo</span>
        </h2>
        <p class="showcase-desc">
          Más allá de la consultoría, construimos. Esta plataforma es una demostración real de nuestras capacidades técnicas, diseñada como un laboratorio de innovación donde aplicamos los estándares de arquitectura que promovemos.
        </p>
        
        <ul class="lux-feature-list">
          <li>
            <div class="icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <div>
              <strong>Laboratorio de Ingeniería</strong>
              <span>Experimentación con patrones de diseño avanzados y escalabilidad.</span>
            </div>
          </li>
          <li>
            <div class="icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <div>
              <strong>Demostración Técnica</strong>
              <span>Un entorno real donde la teoría de arquitectura se convierte en software.</span>
            </div>
          </li>
        </ul>

        <div style="margin-top: 3rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <Button href="https://app.intellecto.com.co" target="_blank" class="lux-explore-btn">
            Ver Demo Técnica
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 10px;"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </Button>
          <Button href="/intellecto-app" variant="secondary" style="border-color: rgba(var(--color-accent-rgb), 0.2);">
            Conocer la Ingeniería
          </Button>
        </div>
      </div>

      <!-- Visual Side -->
      <div class="showcase-visual reveal delay-200">
        <GlassCard class="app-mockup-wrap">
          <div class="mockup-header">
            <div class="dots"><span></span><span></span><span></span></div>
            <div class="address-bar">app.intellecto.com.co</div>
          </div>
          <div class="mockup-body">
            <!-- Simulated App UI -->
            <div class="ui-skeleton">
              <aside class="ui-side-nav">
                <div class="ui-item"></div>
                <div class="ui-item"></div>
                <div class="ui-item active"></div>
                <div class="ui-item"></div>
              </aside>
              <main class="ui-main">
                <header class="ui-top">
                  <div class="ui-pill"></div>
                  <div class="ui-pill wider"></div>
                </header>
                <div class="ui-grid">
                  <div class="ui-card lux-glow-subtle"></div>
                  <div class="ui-card"></div>
                  <div class="ui-card wider"></div>
                </div>
              </main>
            </div>
            <!-- Glow effect -->
            <div class="mockup-glow"></div>
          </div>
        </GlassCard>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase-container {
    background: radial-gradient(circle at 0% 50%, rgba(var(--color-accent-rgb), 0.05), transparent 40%);
    padding: 8rem 0;
    overflow: hidden;
  }

  .grid-showcase {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .grid-showcase {
      grid-template-columns: 1fr 1.2fr;
      gap: 6rem;
    }
  }

  .showcase-content {
    max-width: 600px;
  }

  .showcase-desc {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 3rem;
  }

  .lux-feature-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .lux-feature-list li {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(var(--color-accent-rgb), 0.1);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid rgba(var(--color-accent-rgb), 0.2);
  }

  .lux-feature-list li strong {
    display: block;
    font-size: 1.1rem;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .lux-feature-list li span {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  /* Mockup Styles */
  .app-mockup-wrap {
    position: relative;
    padding: 0;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 16/10;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: var(--shadow-2xl);
    transform: perspective(1000px) rotateY(-5deg) rotateX(2deg);
    transition: all 0.6s var(--ease-out-expo);
  }

  .app-mockup-wrap:hover {
    transform: perspective(1000px) rotateY(0deg) rotateX(0deg) scale(1.02);
    border-color: rgba(var(--color-accent-rgb), 0.3);
  }

  .mockup-header {
    background: rgba(var(--color-bg-secondary-rgb), 0.8);
    height: 44px;
    display: flex;
    align-items: center;
    padding: 0 1.25rem;
    gap: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dots {
    display: flex;
    gap: 6px;
  }

  .dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
  }

  .address-bar {
    flex: 1;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 6px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .mockup-body {
    background: #000;
    height: 100%;
    padding: 1.5rem;
    position: relative;
  }

  .ui-skeleton {
    display: flex;
    gap: 1.5rem;
    height: 100%;
  }

  .ui-side-nav {
    width: 40px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .ui-item {
    height: 40px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 10px;
  }

  .ui-item.active {
    background: var(--color-accent);
  }

  .ui-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .ui-top {
    display: flex;
    gap: 1rem;
  }

  .ui-pill {
    height: 30px;
    width: 80px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 100px;
  }

  .ui-pill.wider { width: 140px; }

  .ui-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .ui-card {
    height: 120px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .ui-card.wider {
    grid-column: span 2;
    height: 180px;
  }

  .lux-glow-subtle {
    box-shadow: inset 0 0 40px rgba(var(--color-accent-rgb), 0.1);
    border-color: rgba(var(--color-accent-rgb), 0.2) !important;
  }

  .mockup-glow {
    position: absolute;
    width: 150%;
    height: 150%;
    background: radial-gradient(circle at center, rgba(var(--color-accent-rgb), 0.15), transparent 70%);
    top: -25%;
    left: -25%;
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
  }
</style>
