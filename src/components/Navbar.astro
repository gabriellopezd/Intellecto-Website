<header id="navbar" class="navbar">
  <nav class="nav-inner">
    <!-- Logo -->
    <a href="/" style="display: flex; align-items: center; gap: 10px; position: relative; z-index: 10;">
      <img src="/Logo_Intellecto-NoBg.png" alt="Intellecto Logo" style="height: 36px; width: 36px;">
      <div>
        <span class="logo-text">Intellecto</span>
        <span class="logo-subtitle">Soluciones Digitales</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="nav-links">
      <a href="/" class="nav-link">Inicio</a>
      <a href="/servicios" class="nav-link">Servicios</a>
      <a href="/portafolio" class="nav-link">Portafolio</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/nuestro-equipo" class="nav-link">Nuestro Equipo</a>
    </div>

    <!-- Actions -->
    <div style="display: flex; align-items: center; gap: 10px;">
      <!-- CTA Desktop -->
      <a href="#contact" class="nav-cta">
        Contacto
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>

      <!-- Theme Toggle -->
      <button id="theme-toggle" class="theme-toggle" aria-label="Cambiar tema">
        <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      </button>

      <!-- Mobile Hamburger -->
      <button id="menu-toggle" class="hamburger" aria-label="Menú">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="mobile-menu">
  <a href="/" class="mobile-nav-link">
    <div class="mobile-nav-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    </div>
    Inicio
  </a>
  <a href="/servicios" class="mobile-nav-link">
    <div class="mobile-nav-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.063 2.365 12.48a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.581-6.135a.5.5 0 0 1 .964 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
    </div>
    Servicios
  </a>
  <a href="/portafolio" class="mobile-nav-link">
    <div class="mobile-nav-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg>
    </div>
    Portafolio
  </a>
  <a href="/blog" class="mobile-nav-link">
    <div class="mobile-nav-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
    </div>
    Blog
  </a>
   <a href="/nuestro-equipo" class="mobile-nav-link">
    <div class="mobile-nav-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
    </div>
    Nuestro Equipo
  </a>
  <div style="margin-top: 1.5rem;">
    <a href="#contact" class="btn btn-primary btn-full" id="mobile-contact">Contáctanos</a>
  </div>
</div>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    transition: all 0.5s var(--ease-out-expo);
  }

  .navbar-scrolled {
    background: rgba(var(--color-bg-rgb), 0.7);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 
      0 10px 40px -10px rgba(0, 0, 0, 0.3),
      inset 0 -1px 0 0 rgba(255, 255, 255, 0.03);
  }

  .light .navbar-scrolled {
    background: rgba(255, 255, 255, 0.8);
    border-bottom-color: rgba(0, 0, 0, 0.05);
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.05);
  }

  .nav-inner {
    width: 100%;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.03);
    padding: 6px;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .light .nav-links {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.04);
  }

  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    padding: 8px 18px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    transition: all 0.3s ease;
    letter-spacing: 0.01em;
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.08);
  }

  .light .nav-link:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .nav-link.active {
    color: var(--color-accent);
    background: rgba(var(--color-accent-rgb), 0.1);
  }

  .nav-system-btn {
    display: none;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    background: rgba(var(--color-accent-rgb), 0.05);
    border: 1px solid rgba(var(--color-accent-rgb), 0.4);
    color: var(--color-accent);
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 100px;
    transition: all 0.4s var(--ease-out-expo);
    text-decoration: none;
    backdrop-filter: blur(10px);
  }

  @media (min-width: 1024px) {
    .nav-system-btn {
      display: flex;
    }
  }

  .nav-system-btn:hover {
    background: var(--color-accent);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(var(--color-accent-rgb), 0.4);
  }

  .nav-cta {
    display: none;
    padding: 10px 22px;
    border-radius: 100px;
    background: var(--color-accent);
    color: white;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.4s var(--ease-out-expo);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  @media (min-width: 768px) {
    .nav-cta {
      display: flex;
      align-items: center;
      gap: 8px;
    }
  }

  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(var(--color-accent-rgb), 0.5);
    filter: brightness(1.1);
  }

  .theme-toggle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .theme-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: rotate(15deg);
    border-color: var(--color-accent);
  }

  .sun-icon { display: none; }
  .moon-icon { display: block; }
  
  .light .sun-icon { display: block; }
  .light .moon-icon { display: none; }

  .mobile-menu {
    position: fixed;
    top: 0;
    right: -100%;
    width: 100%;
    height: 100vh;
    background: var(--color-bg);
    z-index: 1000;
    display: flex;
    flex-direction: column;
    padding: 100px 2rem 2rem;
    transition: right 0.4s var(--ease-out-expo);
  }

  .mobile-menu.open {
    right: 0;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .mobile-system-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px;
    background: rgba(var(--color-accent-rgb), 0.1);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 16px;
    font-weight: 800;
    text-decoration: none;
    margin-bottom: 0.5rem;
  }
</style>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('navbar-scrolled');
    } else {
      navbar?.classList.remove('navbar-scrolled');
    }
  }, { passive: true });

  // Mobile menu toggle
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
    document.body.style.overflow = mobileMenu?.classList.contains('open') ? 'hidden' : '';
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // Theme Toggle Logic
  const themeToggle = document.getElementById('theme-toggle');
  
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    const newTheme = isDark ? 'light' : 'dark';
    
    // Add transition class to animate everything smoothly
    document.documentElement.classList.add('theme-transitioning');
    
    if (newTheme === 'light') {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
    } else {
      document.documentElement.classList.remove('light');
      document.documentElement.classList.add('dark');
    }
    
    localStorage.setItem('theme', newTheme);
    
    // Remove transition class after animation finished
    setTimeout(() => {
      document.documentElement.classList.remove('theme-transitioning');
    }, 400);
  });
</script>
