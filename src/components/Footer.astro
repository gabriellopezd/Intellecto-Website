---
---
<footer style="position: relative; overflow: hidden; background: var(--color-bg-secondary);">
  <!-- Top gradient line -->
  <div style="position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent 5%, var(--color-accent) 35%, var(--color-secondary) 65%, transparent 95%);"></div>

  <!-- Background orbs -->
  <div style="position: absolute; inset: 0; overflow: hidden; pointer-events: none;">
    <div class="glow-orb animate-pulse-glow" style="width: 250px; height: 250px; background: var(--color-accent); opacity: 0.04; top: -60px; right: -60px;"></div>
    <div class="glow-orb animate-pulse-glow" style="width: 250px; height: 250px; background: var(--color-secondary); opacity: 0.04; bottom: -60px; left: -60px; animation-delay: 2s;"></div>
  </div>

  <div class="container-main footer-section" style="position: relative; z-index: 10;">
    <div class="grid-footer" style="margin-bottom: 2.5rem;">
      <!-- Brand -->
      <div>
        <a href="/" style="display: flex; align-items: center; gap: 12px; margin-bottom: 1.5rem;">
          <img src="/Logo_Intellecto-NoBg.png" alt="Intellecto Logo" style="height: 40px; width: 40px;">
          <div>
            <span class="logo-text" style="display: block; font-size: 1.25rem;">Intellecto</span>
             <span class="logo-subtitle" style="display: block; font-size: 0.7rem; opacity: 0.6;">Estrategia & Tecnología</span>
          </div>
        </a>
        <p style="font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 2rem; max-width: 300px;">
          Liderando el futuro de la arquitectura empresarial mediante innovación, datos y soluciones TI de alta escala.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 style="font-family: var(--font-display); font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-primary); margin-bottom: 2rem; display: flex; align-items: center; gap: 10px;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); box-shadow: 0 0 10px var(--color-accent);"></span>
          Compañía
        </h4>
        <div style="display: flex; flex-direction: column; gap: 15px;">
          <a href="/servicios" class="footer-link-lux">Nuestros Servicios</a>
          <a href="/portafolio" class="footer-link-lux">Portafolio de Éxito</a>
          <a href="/nuestro-equipo" class="footer-link-lux">Talento Intellecto</a>
          <a href="/blog" class="footer-link-lux">Radar de Innovación</a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 style="font-family: var(--font-display); font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-primary); margin-bottom: 2rem; display: flex; align-items: center; gap: 10px;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-secondary); box-shadow: 0 0 10px var(--color-secondary);"></span>
          Soluciones
        </h4>
        <div style="display: flex; flex-direction: column; gap: 15px;">
          <a href="/servicios#arquitectura" class="footer-link-lux">Arquitectura Empresarial</a>
          <a href="/servicios#transformacion" class="footer-link-lux">Transformación Digital</a>
          <a href="/servicios#consultoria" class="footer-link-lux">Consultoría de Élite</a>
          <a href="/servicios#datos" class="footer-link-lux">Gobierno de Datos</a>
        </div>
      </div>

      <!-- Social -->
      <div>
        <h4 style="font-family: var(--font-display); font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-primary); margin-bottom: 2rem; display: flex; align-items: center; gap: 10px;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: #fbbf24; box-shadow: 0 0 10px #fbbf24;"></span>
          Contacto
        </h4>
        <div style="display: flex; gap: 12px; margin-bottom: 2rem;">
          <a href="mailto:contacto@intellecto.com.co" class="social-icon-lux" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
          <a href="https://linkedin.com/company/intellecto" target="_blank" rel="noopener noreferrer" class="social-icon-lux" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
        <a href="#contact" class="btn-lux">
          <span>Iniciemos un Proyecto</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

    <!-- Bottom -->
    <div style="height: 1px; background: rgba(255, 255, 255, 0.05); margin-bottom: 2.5rem;"></div>
    <div style="display: flex; flex-direction: column; align-items: center; gap: 12px; font-size: 0.85rem; color: var(--color-text-muted); text-align: center;">
      <p>© 2026 Intellecto. Todos los derechos reservados.</p>
      <div style="display: flex; align-items: center; gap: 10px; opacity: 0.8;">
        <span>Certificación de Excelencia TI</span>
        <span style="width: 4px; height: 4px; border-radius: 50%; background: currentColor;"></span>
        <span>Hecho en Colombia</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link-lux {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    transition: all 0.3s ease;
    display: inline-block;
  }
  .footer-link-lux:hover {
    color: var(--color-accent);
    transform: translateX(5px);
  }
  .social-icon-lux {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    transition: all 0.4s var(--ease-out-expo);
  }
  .social-icon-lux:hover {
    background: var(--color-accent);
    color: white;
    transform: translateY(-5px);
    box-shadow: 0 10px 20px -5px rgba(var(--color-accent-rgb), 0.4);
  }
  .btn-lux {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 24px;
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 12px;
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.4s var(--ease-out-expo);
    cursor: pointer;
  }
  .btn-lux:hover {
    background: var(--color-accent);
    color: white;
    box-shadow: 0 15px 30px -10px rgba(var(--color-accent-rgb), 0.4);
    transform: translateY(-2px);
  }
</style>
  </div>
</footer>
