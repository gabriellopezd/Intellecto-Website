---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portafolio de Soluciones - Intellecto">
  <!-- ===== PORTFOLIO HERO SECTION ===== -->
  <section class="section" style="padding-top: calc(var(--nav-height) + 3rem); text-align: center;">
    <div class="container-main">
      <div class="reveal">
        <div class="section-tag">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
          Casos de Éxito
        </div>
        <h1 class="section-title">
          Nuestro <span class="gradient-text">Portafolio</span>
        </h1>
        <p class="section-subtitle" style="max-width: 600px; margin: 1rem auto 0;">
          Proyectos de Arquitectura Empresarial, Transformación Digital y Gobierno de Datos que han generado un impacto medible.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== PROJECTS LIST ===== -->
  <section class="section">
    <div class="container-main">
      <div class="project-list">

        <!-- Project 1 -->
        <div class="glass-card project-item reveal">
          <div class="project-header">
            <h2 class="project-title">Programa de Transformación Digital del Sector Justicia</h2>
            <span class="project-client">Ministerio de Justicia y del Derecho – Colombia</span>
          </div>
          <div class="project-details">
            <div class="project-info">
              <p><strong>Rol:</strong> Arquitecto Empresarial y Líder de Proyectos</p>
              <p><strong>Periodo:</strong> 2021 – 2025</p>
            </div>
            <p class="project-description">Liderazgo de la planificación y ejecución de iniciativas de transformación digital bajo enfoque de Arquitectura Empresarial, alineadas con Gobierno Digital y estrategia sectorial del sistema de justicia colombiano.</p>
            <h4 class="tech-stack-title">Tecnologías y Marcos</h4>
            <div class="tech-stack">
              <span class="skill-tag">TOGAF</span>
              <span class="skill-tag">COBIT</span>
              <span class="skill-tag">SCRUM / Agile</span>
              <span class="skill-tag">Power BI</span>
            </div>
            <h4 class="results-title">Resultados Clave</h4>
            <ul class="results-list">
              <li>Liderazgo de ejercicios institucionales de Arquitectura Empresarial.</li>
              <li>Modernización y estandarización de procesos y políticas TI.</li>
              <li>Fortalecimiento del gobierno tecnológico del ministerio.</li>
            </ul>
          </div>
        </div>

        <!-- Project 2 -->
        <div class="glass-card project-item reveal">
          <div class="project-header">
            <h2 class="project-title">Hoja de Ruta de Transformación con Arquitectura Empresarial</h2>
            <span class="project-client">Centro Nacional de Memoria Histórica – Colombia</span>
          </div>
          <div class="project-details">
            <div class="project-info">
              <p><strong>Rol:</strong> Arquitecto Empresarial y Líder de Proyectos</p>
              <p><strong>Periodo:</strong> 2024 – 2025</p>
            </div>
            <p class="project-description">Diseño e implementación del marco de Arquitectura Empresarial para impulsar la transformación digital institucional mediante la optimización de procesos, sistemas y gestión de la información.</p>
            <h4 class="tech-stack-title">Tecnologías y Marcos</h4>
            <div class="tech-stack">
              <span class="skill-tag">MRAE MinTIC</span>
              <span class="skill-tag">TOGAF</span>
              <span class="skill-tag">BPM</span>
              <span class="skill-tag">SCRUM / Agile</span>
            </div>
            <h4 class="results-title">Resultados Clave</h4>
            <ul class="results-list">
              <li>Roadmap institucional de transformación digital.</li>
              <li>Portafolio de proyectos priorizados para cierre de brechas.</li>
            </ul>
          </div>
        </div>

        <!-- Project 3 -->
        <div class="glass-card project-item reveal">
          <div class="project-header">
            <h2 class="project-title">Arquitectura Digital Nacional de Migración</h2>
            <span class="project-client">Ministerio del Interior – Ecuador (BID / Wegital)</span>
          </div>
          <div class="project-details">
            <div class="project-info">
              <p><strong>Rol:</strong> Arquitecto Empresarial y de Datos</p>
            </div>
            <p class="project-description">Definición de arquitectura de solución para modernización de los servicios digitales de la Subsecretaría de Migración del Ecuador.</p>
            <h4 class="tech-stack-title">Tecnologías y Marcos</h4>
            <div class="tech-stack">
              <span class="skill-tag">TOGAF</span>
               <span class="skill-tag">Arquitectura de Datos</span>
              <span class="skill-tag">SQL / Python</span>
            </div>
            <h4 class="results-title">Resultado Clave</h4>
            <ul class="results-list">
              <li>Arquitectura de solución definida para el sector migración.</li>
            </ul>
          </div>
        </div>

        <!-- Project 4 -->
        <div class="glass-card project-item reveal">
          <div class="project-header">
            <h2 class="project-title">Transformación Digital de Migración Colombia</h2>
            <span class="project-client">Migración Colombia – MinRelaciones Exteriores</span>
          </div>
          <div class="project-details">
            <div class="project-info">
              <p><strong>Rol:</strong> Arquitecto de Procesos y de Datos</p>
            </div>
            <p class="project-description">Definición de Arquitectura Empresarial para impulsar la transformación digital de los servicios migratorios nacionales.</p>
            <h4 class="tech-stack-title">Tecnologías y Marcos</h4>
            <div class="tech-stack">
              <span class="skill-tag">BPM / Agile</span>
              <span class="skill-tag">TOGAF</span>
              <span class="skill-tag">SQL / Python</span>
            </div>
            <h4 class="results-title">Resultado Clave</h4>
            <ul class="results-list">
              <li>Arquitectura Empresarial definida para habilitar la transformación digital.</li>
            </ul>
          </div>
        </div>
        
        <!-- Project 5 -->
        <div class="glass-card project-item reveal">
          <div class="project-header">
            <h2 class="project-title">Modernización de Procesos del Sector Público</h2>
            <span class="project-client">Instituto Nacional de Aprendizaje – Costa Rica</span>
          </div>
          <div class="project-details">
            <div class="project-info">
              <p><strong>Rol:</strong> Arquitecto Empresarial</p>
            </div>
            <p class="project-description">Consultoría para la definición de la arquitectura de procesos de una institución nacional de formación y empleo.</p>
            <h4 class="tech-stack-title">Tecnologías y Marcos</h4>
            <div class="tech-stack">
              <span class="skill-tag">BPM</span>
              <span class="skill-tag">Arquitectura Empresarial</span>
              <span class="skill-tag">TOGAF / COBIT</span>
            </div>
            <h4 class="results-title">Resultado Clave</h4>
            <ul class="results-list">
              <li>Arquitectura de procesos institucional definida.</li>
            </ul>
          </div>
        </div>

        <!-- Project 6 -->
        <div class="glass-card project-item reveal">
          <div class="project-header">
            <h2 class="project-title">Gobierno de Datos y Plataforma Analítica</h2>
            <span class="project-client">Ministerio de Justicia y del Derecho</span>
          </div>
          <div class="project-details">
            <div class="project-info">
              <p><strong>Rol:</strong> Arquitecto de Datos y Procesos</p>
            </div>
            <p class="project-description">Diseño e implementación de capacidades de gobierno de datos, BI y procesos ETL para soporte a la toma de decisiones.</p>
            <h4 class="tech-stack-title">Tecnologías</h4>
            <div class="tech-stack">
              <span class="skill-tag">SQL</span>
              <span class="skill-tag">ETL</span>
              <span class="skill-tag">Power BI</span>
              <span class="skill-tag">Python</span>
            </div>
            <h4 class="results-title">Resultados Clave</h4>
            <ul class="results-list">
              <li>Procesos ETL implementados.</li>
              <li>Capacidades analíticas para toma de decisiones.</li>
            </ul>
          </div>
        </div>

        <!-- Project 7 -->
        <div class="glass-card project-item reveal">
          <div class="project-header">
            <h2 class="project-title">Portal Web de Gobierno Inteligente</h2>
            <span class="project-client">Alcaldía de Montería</span>
          </div>
          <div class="project-details">
            <div class="project-info">
              <p><strong>Rol:</strong> Líder de Gobierno Digital y Arquitecto de Sistemas</p>
            </div>
            <p class="project-description">Liderazgo de la implementación del portal web institucional bajo enfoque de Arquitectura de Solución.</p>
            <h4 class="tech-stack-title">Tecnologías</h4>
            <div class="tech-stack">
              <span class="skill-tag">HTML / CSS / JS</span>
              <span class="skill-tag">Arquitectura de Solución</span>
            </div>
            <h4 class="results-title">Resultado Clave</h4>
            <ul class="results-list">
              <li>Portal web institucional implementado.</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .project-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .project-item {
    padding: 2rem;
  }
  .project-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }
  .project-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }
  .project-client {
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 500;
  }
  .project-details .project-info {
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
  .project-details .project-info p {
    margin: 0.25rem 0;
  }
  .project-description {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .tech-stack-title, .results-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-secondary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .results-list {
    list-style-type: none;
    padding-left: 0;
    font-size: 0.9rem;
  }
  .results-list li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 0.5rem;
  }
  .results-list li::before {
    content: '✔';
    position: absolute;
    left: 0;
    color: var(--color-teal);
  }
</style>
