---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';

// Obtenemos todos los proyectos desde la colección de contenido de Astro
const projects = await getCollection('portfolio');

const filterCategories = [
	{ id: 'all', label: 'Todos', color: 'var(--color-text-primary)' },
	{ id: 'ea', label: 'Arquitectura Empresarial', color: '#60a5fa' },
	{ id: 'transformacion', label: 'Transformación Digital', color: '#c084fc' },
	{ id: 'datos', label: 'Gobierno de Datos', color: '#2dd4bf' }
];
---

<Layout title="Portafolio Premium - Intellecto">
	<div class="portafolio-bg-elements">
		<div class="blob-1"></div>
		<div class="blob-2"></div>
	</div>

	<!-- ===== PORTFOLIO HERO SECTION ===== -->
	<section class="section" style="padding-top: calc(var(--nav-height) + 4rem); text-align: center; position: relative;">
		<div class="container-main">
			<div class="reveal">
				<div class="section-tag section-tag-purple">
					<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
					Expertise Comprobada
				</div>
				<h1 class="section-title">
					Nuestros <span class="gradient-text">Casos de Éxito</span>
				</h1>
				<p class="section-subtitle" style="max-width: 650px; margin: 1.5rem auto 0;">
					Un recorrido por los proyectos estratégicos de mayor impacto que hemos liderado en el sector público y privado de Latinoamérica.
				</p>
			</div>
		</div>
	</section>

	<!-- ===== FILTER SECTION ===== -->
	<section class="filter-section">
		<div class="container-main">
			<div class="filter-container reveal">
				{filterCategories.map(cat => (
					<button 
						class={`filter-btn ${cat.id === 'all' ? 'active' : ''}`} 
						data-filter={cat.id}
						style={`--hover-color: ${cat.color}`}
					>
						{cat.label}
					</button>
				))}
			</div>
		</div>
	</section>

	<!-- ===== PROJECTS GRID ===== -->
	<section class="section projects-grid-section">
		<div class="container-main">
			<div class="project-list-premium">
				{projects.map((project) => (
					<ProjectCard {...project.data} />
				))}
			</div>
		</div>
	</section>

	<section class="section cta-final">
		<div class="container-main">
			<div class="reveal glass-panel-cta">
				<div class="cta-content">
					<h2>¿Listo para iniciar su transformación?</h2>
					<p>Permítanos ayudarle a diseñar el futuro tecnológico de su organización.</p>
					<Button href="/#contact" variant="blue" size="full">Agendar Consultoría</Button>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	// Logic for Filtering
	const filterButtons = document.querySelectorAll('.filter-btn');
	const projectItems = document.querySelectorAll('.project-card-wrapper');

	filterButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			// Update active button
			filterButtons.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');

			const filterValue = btn.getAttribute('data-filter');

			projectItems.forEach(item => {
				const category = item.getAttribute('data-category');
				
				if (filterValue === 'all' || filterValue === category) {
					item.style.display = 'block';
					setTimeout(() => {
						item.style.opacity = '1';
						item.style.transform = 'scale(1)';
					}, 10);
				} else {
					item.style.opacity = '0';
					item.style.transform = 'scale(0.95)';
					setTimeout(() => {
						item.style.display = 'none';
					}, 400);
				}
			});
		});
	});
</script>

<style>
	.portafolio-bg-elements {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: -1;
		overflow: hidden;
	}
	.blob-1 {
		position: absolute;
		top: 10%;
		right: -10%;
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(0, 212, 255, 0.05) 0%, transparent 70%);
		filter: blur(80px);
		animation: float 20s infinite ease-in-out;
	}
	.blob-2 {
		position: absolute;
		bottom: 10%;
		left: -10%;
		width: 500px;
		height: 500px;
		background: radial-gradient(circle, rgba(168, 85, 247, 0.05) 0%, transparent 70%);
		filter: blur(80px);
		animation: float 15s infinite ease-in-out reverse;
	}
	
	@keyframes float {
		0%, 100% { transform: translate(0, 0); }
		50% { transform: translate(30px, 20px); }
	}

	.filter-section {
		padding: 2rem 0;
		position: sticky;
		top: var(--nav-height);
		z-index: 50;
		background: rgba(var(--color-bg-rgb), 0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--color-border);
	}

	.filter-container {
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.filter-btn {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--color-border);
		padding: 10px 22px;
		border-radius: 30px;
		color: var(--color-text-secondary);
		font-weight: 600;
		font-size: 0.9rem;
		cursor: pointer;
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		white-space: nowrap;
	}

	.filter-btn:hover {
		border-color: var(--hover-color);
		color: var(--hover-color);
		background: rgba(255, 255, 255, 0.06);
		transform: translateY(-2px);
	}

	.filter-btn.active {
		background: var(--gradient-accent);
		color: white;
		border-color: transparent;
		box-shadow: 0 10px 20px -5px rgba(var(--color-accent-rgb), 0.3);
	}

	.project-list-premium {
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		margin-top: 2rem;
	}

	@media (min-width: 1024px) {
		.project-list-premium {
			gap: 5rem;
		}
	}

	.cta-final {
		padding: 8rem 0;
	}

	.glass-panel-cta {
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 32px;
		padding: 4rem;
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	.cta-content {
		position: relative;
		z-index: 1;
		max-width: 500px;
		margin: 0 auto;
	}

	.cta-content h2 {
		font-family: var(--font-display);
		font-size: 2.25rem;
		font-weight: 900;
		margin-bottom: 1rem;
		color: var(--color-text-primary);
	}

	.cta-content p {
		font-size: 1.1rem;
		color: var(--color-text-secondary);
		margin-bottom: 2.5rem;
		line-height: 1.6;
	}
</style>
