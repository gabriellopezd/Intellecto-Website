---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/ui/BlogCard.astro';

const allPosts = await getCollection('blog');

// Sort by date desc
const posts = allPosts.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Group by category
const noticias = posts.filter(p => p.data.category === 'noticia');
const cientificos = posts.filter(p => p.data.category === 'cientifico');
const iaSemanal = posts.filter(p => p.data.category === 'ia-semanal');

const sections = [
	{ id: 'noticias', title: 'Últimas Noticias', icon: '📰', data: noticias, color: 'var(--color-accent)' },
	{ id: 'ciencia', title: 'Artículos Científicos', icon: '🔬', data: cientificos, color: 'var(--color-secondary)' },
	{ id: 'ia', title: 'IA Semanal', icon: '🤖', data: iaSemanal, color: 'var(--color-amber)' }
];
---

<Layout title="Blog y Conocimiento - Intellecto">
	<section class="section" style="padding-top: calc(var(--nav-height) + 6rem);">
		<div class="container-main">
			<div class="reveal" style="text-align: center; margin-bottom: 6rem;">
				<div class="section-tag">
					<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
					Hub de Conocimiento
				</div>
				<h1 class="section-title">
					Explora nuestro <span class="gradient-text-lux">Conocimiento</span>
				</h1>
				<p class="section-subtitle" style="max-width: 750px; margin: 2rem auto 0; font-size: 1.25rem;">
					Información estratégica, análisis técnico y tendencias de IA diseñadas para líderes que definen el mañana.
				</p>
			</div>

			<!-- Navigation Anchors -->
			<div class="blog-lux-nav reveal">
				{sections.map(section => (
					<a href={`#${section.id}`} class="blog-lux-nav-item">
						<span class="nav-lux-icon" style={`background: rgba(var(--color-accent-rgb), 0.1); color: var(--color-accent);`}>{section.icon}</span>
						<div class="nav-lux-text">
							<span class="label">Explorar</span>
							<span class="title">{section.title}</span>
						</div>
					</a>
				))}
			</div>

			<!-- Blog Sections -->
			{sections.map((section) => (
				<div id={section.id} class="blog-lux-section-block">
					<div class="section-lux-header-mini reveal">
						<div class="header-inner">
						  <h2 class="mini-lux-title">
						    <span class="icon">{section.icon}</span>
						    {section.title}
						  </h2>
						  <div class="lux-title-line"></div>
						</div>
					</div>

					{section.data.length > 0 ? (
						<div class="blog-lux-grid">
							{section.data.map((post) => (
								<BlogCard 
									title={post.data.title}
									description={post.data.description}
									pubDate={post.data.pubDate}
									heroImage={post.data.heroImage}
									url={`/blog/${post.slug}`}
									tags={post.data.tags}
									category={post.data.category}
								/>
							))}
						</div>
					) : (
						<div class="empty-lux-state reveal">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.3; margin-bottom: 1.5rem;"><path d="m14 2 6 6v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8z"/><path d="M14 2v6h6"/><path d="M9 15h6"/><path d="M9 11h6"/></svg>
							<p>Contenido premium en fase de redacción. Vuelva pronto.</p>
						</div>
					)}
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
	.blog-lux-nav {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
		margin-bottom: 8rem;
	}

	.blog-lux-nav-item {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		padding: 1.5rem;
		background: rgba(var(--color-bg-secondary-rgb), 0.5);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 24px;
		text-decoration: none;
		transition: all 0.4s var(--ease-out-expo);
		backdrop-filter: blur(10px);
	}

	.light .blog-lux-nav-item {
		background: rgba(255, 255, 255, 0.8);
		border-color: rgba(0, 0, 0, 0.05);
	}

	.blog-lux-nav-item:hover {
		transform: translateY(-8px);
		background: rgba(var(--color-accent-rgb), 0.05);
		border-color: var(--color-accent);
		box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.2);
	}

	.nav-lux-icon {
		width: 52px;
		height: 52px;
		border-radius: 14px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.5rem;
	}
	
	.nav-lux-text {
		display: flex;
		flex-direction: column;
	}

	.nav-lux-text .label {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--color-accent);
		font-weight: 800;
		margin-bottom: 2px;
	}

	.nav-lux-text .title {
		font-family: var(--font-display);
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--color-text-primary);
	}
	
	.blog-lux-section-block {
		margin-bottom: 10rem;
		scroll-margin-top: calc(var(--nav-height) + 4rem);
	}

	.section-lux-header-mini .header-inner {
		display: flex;
		align-items: center;
		gap: 2.5rem;
		margin-bottom: 4rem;
	}

	.mini-lux-title {
		font-family: var(--font-display);
		font-size: 2.25rem;
		font-weight: 300;
		color: var(--color-text-primary);
		white-space: nowrap;
		letter-spacing: -0.02em;
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.mini-lux-title .icon {
		font-size: 1.75rem;
		filter: drop-shadow(0 0 10px rgba(var(--color-accent-rgb), 0.3));
	}

	.lux-title-line {
		height: 1px;
		flex: 1;
		background: linear-gradient(90deg, rgba(var(--color-accent-rgb), 0.2), transparent);
	}
	
	.blog-lux-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
		gap: 3rem;
	}
	
	.empty-lux-state {
		text-align: center;
		padding: 6rem 2rem;
		background: rgba(var(--color-bg-secondary-rgb), 0.3);
		border-radius: 32px;
		border: 1px dashed rgba(255, 255, 255, 0.1);
		color: var(--color-text-muted);
		font-size: 1.1rem;
	}

	.light .empty-lux-state {
		background: rgba(0, 0, 0, 0.02);
		border-color: rgba(0, 0, 0, 0.1);
	}
</style>
