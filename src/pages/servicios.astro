---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/sections/ServiceCard.astro';
import Button from '../components/ui/Button.astro';

const services = [
  {
    id: "arquitectura-empresarial",
    title: "Arquitectura Empresarial",
    shortDesc: "Diseñamos la arquitectura que conecta estrategia, procesos, datos y tecnología.",
    description: "Definimos la arquitectura integral de la organización para alinear negocio y tecnología, reducir complejidad, optimizar inversiones y habilitar la transformación digital sostenible. Ayudamos a entender cómo funciona hoy la organización (AS-IS) y a diseñar cómo debe funcionar en el futuro (TO-BE).",
    includes: [
      "Arquitectura de negocio, datos, aplicaciones y tecnología",
      "Modelado AS-IS / TO-BE",
      "Roadmap de transformación",
      "Gobierno de arquitectura y estándares"
    ],
    techStack: ["TOGAF", "ArchiMate", "MRAE", "BPM", "ABACUS", "Mega HOPEX"]
  },
  {
    id: "transformacion-digital",
    title: "Transformación Digital",
    shortDesc: "Convertimos la estrategia digital en proyectos reales y ejecutables.",
    description: "Acompañamos a las organizaciones en el diseño y ejecución de su transformación digital, integrando procesos, cultura, tecnología y datos. Nuestro enfoque va más allá de la tecnología: impulsamos cambios organizacionales que generan valor real.",
    includes: [
      "Estrategia y hoja de ruta digital",
      "Modernización y automatización de procesos",
      "Gestión del portafolio y del cambio"
    ],
    techStack: ["Agile", "Scrum", "Lean", "Design Thinking", "PMBOK"]
  },
  {
    id: "consultoria-ti",
    title: "Consultoría TI",
    shortDesc: "Diseñamos soluciones tecnológicas escalables, seguras y sostenibles.",
    description: "Apoyamos la toma de decisiones tecnológicas mediante diseño de arquitecturas de solución, modernización de plataformas y optimización del ecosistema TI. Nos enfocamos en crear soluciones robustas y alineadas a la estrategia del negocio.",
    includes: [
      "Arquitectura de soluciones y de datos",
      "Estrategia cloud y modernización",
      "Analítica y Business Intelligence"
    ],
    techStack: ["Cloud", "APIs", "BI", "SQL", "Python", "Power BI"]
  },
  {
    id: "gobierno-digital",
    title: "Gobierno Digital",
    shortDesc: "Implementamos políticas y capacidades de gobierno digital, especialmente en el sector público.",
    description: "Acompañamos a entidades públicas en la implementación de políticas de Gobierno Digital y marcos regulatorios, fortaleciendo la gestión tecnológica y la prestación de servicios digitales. Orientado a sector público LATAM.",
    includes: [
      "Implementación de políticas de Gobierno Digital",
      "Gobierno de TI y datos",
      "Fortalecimiento de capacidades institucionales"
    ],
    techStack: ["MRAE", "COBIT", "ITIL", "Gobierno Digital LATAM"]
  }
];
---

<Layout title="Servicios - Intellecto">
  <!-- ===== SERVICES HERO SECTION ===== -->
  <section class="section" style="padding-top: calc(var(--nav-height) + 3rem); text-align: center;">
    <div class="container-main">
      <div class="reveal">
        <div class="section-tag">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 14.063 2.365 12.48a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.581-6.135a.5.5 0 0 1 .964 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
          Nuestras Capacidades
        </div>
        <h1 class="section-title">
          Servicios de <span class="gradient-text">Transformación</span>
        </h1>
        <p class="section-subtitle" style="max-width: 700px; margin: 1rem auto 0;">
          Ayudamos a organizaciones públicas y privadas a modernizar sus capacidades digitales mediante arquitectura empresarial, datos, nube y transformación organizacional. Nuestro enfoque combina estrategia, tecnología y ejecución para convertir la visión digital en resultados medibles.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES LIST ===== -->
  <section class="section">
    <div class="container-main">
      <div class="services-grid">
        {services.map((service) => (
          <div id={service.id} class="glass-card service-item reveal">
            <div class="service-header">
              <h3 class="service-title">{service.title}</h3>
              <p class="service-short-desc">{service.shortDesc}</p>
            </div>
            <div class="service-details">
              <p>{service.description}</p>
              <h4 class="includes-title">Qué incluye</h4>
              <ul class="includes-list">
                {service.includes.map(item => <li>{item}</li>)}
              </ul>
              <h4 class="tech-stack-title">Marcos y herramientas</h4>
              <div class="tech-stack">
                {service.techStack.map(tech => <span class="skill-tag">{tech}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA SECTION ===== -->
  <section class="section">
    <div class="container-main">
      <div class="cta-banner reveal">
        <div class="cta-content">
          <h2 class="cta-title">¿Listo para impulsar la transformación digital de tu organización?</h2>
          <p class="cta-subtitle">Conversemos sobre tu proyecto.</p>
        </div>
        <Button href="#contact" class="cta-btn">Enviar Mensaje</Button>
      </div>
    </div>
  </section>

</Layout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }
  .service-item {
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }
  .service-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }
  .service-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }
  .service-short-desc {
    font-size: 0.95rem;
    color: var(--color-accent);
    min-height: 40px;
  }
  .service-details p {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .includes-title, .tech-stack-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-secondary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .includes-list {
    list-style-type: none;
    padding-left: 0;
    font-size: 0.9rem;
  }
  .includes-list li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 0.5rem;
  }
  .includes-list li::before {
    content: '›';
    position: absolute;
    left: 0;
    font-weight: bold;
    color: var(--color-teal);
  }
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
</style>
