---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import ServiceCard from '../components/sections/ServiceCard.astro';
import BlogCard from '../components/ui/BlogCard.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';
import Button from '../components/ui/Button.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import AppShowcase from '../components/sections/AppShowcase.astro';
const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredProjects = [
	{
		title: "Programa de Transformación Digital del Sector Justicia",
		client: "Ministerio de Justicia y del Derecho",
		role: "Arquitecto Empresarial y Líder de Proyectos",
		category: "transformacion",
		description: "Liderazgo estratégico para la modernización tecnológica del sistema de justicia colombiano bajo el marco de Gobierno Digital.",
		tech: ["TOGAF", "COBIT", "Agile"],
		results: ["Estandarización de procesos TI", "Modernización tecnológica"]
	},
	{
		title: "Gobierno de Datos y Plataforma Analítica",
		client: "Ministerio de Justicia y del Derecho",
		role: "Arquitecto de Datos",
		category: "datos",
		description: "Diseño de capacidades analíticas avanzadas y procesos ETL para optimizar la toma de decisiones basada en evidencia.",
		tech: ["SQL", "Power BI", "Python"],
		results: ["Procesos ETL automatizados", "Dashboard de control"]
	}
];

const services = [
  {
    title: "Arquitectura Empresarial",
    description: "Alineamos su tecnología con la estrategia corporativa mediante TOGAF y marcos líderes.",
    href: "/servicios#arquitectura-empresarial",
    backgroundImage: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80&w=800"
  },
  {
    title: "Transformación Digital",
    description: "Modernizamos procesos y adoptamos nuevas tecnologías para la era digital.",
    href: "/servicios#transformacion-digital",
    backgroundImage: "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&q=80&w=800"
  },
  {
    title: "Consultoría TI",
    description: "Soluciones tecnológicas robustas para resolver desafíos complejos.",
    href: "/servicios#consultoria-ti",
    backgroundImage: "https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&q=80&w=800"
  },
  {
    title: "Gobierno Digital",
    description: "Asesoría en políticas públicas digitales y servicios para el ciudadano.",
    href: "/servicios#gobierno-digital",
    backgroundImage: "https://images.unsplash.com/photo-1556761175-5973dc0f32e7?auto=format&fit=crop&q=80&w=800"
  }
];
---

<Layout title="Intellecto - Transformación Digital y Arquitectura Empresarial">

  <Hero 
    badge="Estrategia y Tecnología para el Futuro"
    title='Bienvenido a <span class="gradient-text-animated">Intellecto</span>'
    subtitle="Impulsamos la Transformación Digital con soluciones de vanguardia en Arquitectura Empresarial, IA y Gobierno Digital."
  />

  <!-- ===== SERVICES SECTION ===== -->
  <section id="servicios" class="section" style="background: radial-gradient(circle at 70% 20%, rgba(var(--color-accent-rgb), 0.03), transparent 40%);">
    <div class="container-main">
      <div class="reveal" style="text-align: center; margin-bottom: 5rem;">
        <div class="section-tag section-tag-blue">Nuestras Capacidades</div>
        <h2 class="section-title">Soluciones <span class="gradient-text">Estratégicas</span></h2>
        <p class="section-subtitle" style="margin: 1.5rem auto 0; max-width: 600px;">Arquitectura de alto nivel para organizaciones que buscan el liderazgo digital.</p>
      </div>

      <div class="grid-1-2-3" style="gap: clamp(1.5rem, 3vw, 2.5rem);">
        <ServiceCard 
          title="Arquitectura Empresarial" 
          description="Diseñamos el roadmap tecnológico alineado con sus objetivos corporativos más ambiciosos."
          backgroundImage=""
          href="/servicios#arquitectura"
          isMinimal={true}
        />
        <ServiceCard 
          title="Transformación Digital" 
          description="Aceleramos la adopción de tecnologías emergentes para modernizar su operación y cultura."
          backgroundImage="" 
          href="/servicios#transformacion"
          isMinimal={true}
        />
        <ServiceCard 
          title="Gobierno de Datos" 
          description="Estructuramos, protegemos y sacamos valor de su activo más valioso: la información."
          backgroundImage=""
          href="/servicios#datos"
          isMinimal={true}
        />
      </div>
    </div>
  </section>

  <!-- ===== FEATURED PROJECTS SECTION ===== -->
  <section id="casos-exito" class="section" style="background: rgba(var(--color-bg-rgb), 0.3); border-top: 1px solid rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.03);">
    <div class="container-main">
      <header class="hub-header reveal" style="display: flex; justify-content: space-between; align-items: flex-end; gap: clamp(1rem, 3vw, 2rem); margin-bottom: clamp(3rem, 8vw, 5rem); flex-wrap: wrap;">
        <div class="hub-title-area">
          <div class="section-tag section-tag-purple">Expertise Comprobada</div>
          <h2 class="section-title">Casos de <span class="gradient-text">Impacto Real</span></h2>
          <p class="section-subtitle">Exhibición de hitos estratégicos y transformación de gran escala.</p>
        </div>
        <div class="hub-cta">
          <Button href="/portafolio" variant="blue">Ir al Portafolio completo</Button>
        </div>
      </header>

      <div class="featured-projects-list" style="display: flex; flex-direction: column; gap: clamp(0.5rem, 1.5vw, 1rem);">
        {featuredProjects.map(project => (
          <ProjectCard {...project} isUltraCompact={true} />
        ))}
      </div>
    </div>
  </section>

  <!-- ===== APP SHOWCASE SECTION ===== -->
  <AppShowcase />

  <!-- ===== KNOWLEDGE HUB SECTION (BLOG) ===== -->
  <section id="blog" class="section" style="background: radial-gradient(circle at 10% 80%, rgba(var(--color-secondary-rgb), 0.03), transparent 40%);">
    <div class="container-main">
      <header class="hub-header reveal" style="display: flex; justify-content: space-between; align-items: flex-end; gap: clamp(1rem, 3vw, 2rem); margin-bottom: clamp(3rem, 8vw, 5rem); flex-wrap: wrap;">
        <div class="hub-title-area">
          <div class="section-tag section-tag-amber">Centro de Conocimiento</div>
          <h2 class="section-title">Radar de <span class="gradient-text">Innovación</span></h2>
          <p class="section-subtitle">Insights profundos sobre arquitectura, estrategia y el futuro de la IA.</p>
        </div>
        <div class="hub-cta">
          <Button href="/blog" variant="secondary">Ir al Blog completo</Button>
        </div>
      </header>
      
      <div class="grid-1-2-3" style="gap: clamp(1.5rem, 3vw, 2rem);">
        {recentPosts.map((post) => (
          <BlogCard 
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            url={`/blog/${post.slug}`}
            tags={post.data.tags}
            category={post.data.category}
            isMinimal={true}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CONTACT SECTION ===== -->
  <section id="contact" class="section" style="background: var(--color-bg);">
    <div class="container-main">
      <div class="reveal">
        <GlassCard class="cta-card-inner" style="position: relative; overflow: hidden; border-color: var(--border-light); background: var(--color-bg-secondary);">
          <!-- Orbs -->
          <div class="glow-orb animate-pulse-glow" style="width: 180px; height: 180px; background: var(--color-accent); opacity: 0.08; top: -50px; left: -50px;"></div>
          <div class="glow-orb animate-pulse-glow" style="width: 200px; height: 200px; background: var(--color-secondary); opacity: 0.06; bottom: -60px; right: -60px; animation-delay: 2s;"></div>

          <div style="position: relative; z-index: 10; text-align: center;">
            <h2 class="section-title" style="margin-bottom: 0.75rem;">
              ¿Listo para <span class="gradient-text">colaborar</span>?
            </h2>
            <p style="font-size: 0.95rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
              Estamos disponibles para consultoría en Arquitectura Empresarial, Transformación Digital y proyectos de TI.
            </p>

            <div class="cta-form">
              <form>
                <div style="margin-bottom: 1rem; text-align: left;">
                  <label for="name" class="form-label">Nombre</label>
                  <input type="text" id="name" name="name" placeholder="Tu nombre" class="form-input">
                </div>
                <div style="margin-bottom: 1rem; text-align: left;">
                  <label for="email" class="form-label">Email</label>
                  <input type="email" id="email" name="email" placeholder="tu@email.com" class="form-input">
                </div>
                <div style="margin-bottom: 1.5rem; text-align: left;">
                  <label for="message" class="form-label">Mensaje</label>
                  <textarea id="message" name="message" rows="4" placeholder="Cuéntenos sobre su proyecto..." class="form-input" style="resize: none;"></textarea>
                </div>
                <Button type="submit" full={true}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
                  Enviar Mensaje
                </Button>
              </form>
            </div>
          </div>
        </GlassCard>
      </div>
    </div>
  </section>

</Layout>
