---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import GlassCard from '../components/ui/GlassCard.astro';
---

<Layout title="Nuestro Equipo - Intellecto">
  <section style="position: relative; min-height: 85vh; display: flex; align-items: center; overflow: hidden; padding-top: calc(var(--nav-height) + 30px); padding-bottom: 60px; background: var(--color-bg);">

    <!-- Background -->
    <div style="position: absolute; inset: 0; background: var(--gradient-hero);"></div>
    <div class="decoration-grid"></div>
    <div class="glow-orb animate-pulse-glow" style="width: 300px; height: 300px; background: var(--color-secondary); opacity: 0.10; top: 10%; right: -5%;"></div>
    <div class="glow-orb animate-pulse-glow" style="width: 250px; height: 250px; background: var(--color-accent); opacity: 0.08; bottom: 10%; left: -5%; animation-delay: 2s;"></div>

    <div class="container-main" style="position: relative; z-index: 10; text-align: center;">

      <!-- Badge -->
      <div class="section-tag section-tag-purple animate-fade-up" style="margin-bottom: 1.5rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        Nuestro Equipo
      </div>

      <h1 class="hero-title animate-fade-up delay-100" style="margin-bottom: 1.25rem; font-size: clamp(2.5rem, 6vw, 4rem);">
        Conoce a Nuestro <span class="gradient-text-purple">Equipo Directivo</span>
      </h1>

      <GlassCard class="team-profile reveal" style="max-width: 800px; margin: 3rem auto; text-align: left; padding: 2.5rem;">
        <div class="team-flex-container">
          <div class="team-image-wrapper">
             <img src="/images/profile-ceo.png" alt="Gabriel López" class="team-img">
             <div class="team-img-decoration"></div>
          </div>
          <div class="team-info">
            <h2 class="team-name">Gabriel López</h2>
            <p class="team-role">CEO y Gerente de Proyectos</p>
            <p class="team-bio">
              Líder con más de 8 años de experiencia en la intersección de la tecnología, la gestión de proyectos y la estrategia empresarial. Experto en Arquitectura Empresarial (TOGAF), Transformación Digital y Gobierno Digital. Apasionado por construir soluciones innovadoras que impulsan el crecimiento y la eficiencia.
            </p>
             <div class="animate-fade-up delay-300" style="margin-top: 2rem;">
                <Button 
                  href="/CV Esp Gabriel Lopez 2026.pdf"
                  variant="blue"
                  class="btn-purple"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  Descargar Perfil Completo (PDF)
                </Button>
            </div>
          </div>
        </div>
      </GlassCard>

    </div>
  </section>
</Layout>

<style>
  .team-flex-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .team-flex-container {
      flex-direction: row;
      align-items: flex-start;
    }
  }
  .team-image-wrapper {
    position: relative;
    flex-shrink: 0;
  }
  .team-img {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    border: 4px solid var(--color-accent);
    object-fit: cover;
    position: relative;
    z-index: 2;
    box-shadow: var(--shadow-xl);
  }
  .team-img-decoration {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: var(--gradient-accent);
    opacity: 0.2;
    filter: blur(15px);
    z-index: 1;
  }
  .team-info {
    flex: 1;
  }
  .team-name {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }
  .team-role {
    font-weight: 600;
    color: var(--color-accent);
    font-size: 1.1rem;
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
  }
  .team-bio {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }
</style>
