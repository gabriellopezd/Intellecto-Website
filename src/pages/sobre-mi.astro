---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sobre Mí - Gabriel López | Arquitecto Empresarial">
  <section style="position: relative; min-height: 85vh; display: flex; align-items: center; overflow: hidden; padding-top: calc(var(--nav-height) + 30px); padding-bottom: 60px; background: var(--color-bg);">

    <!-- Background -->
    <div style="position: absolute; inset: 0; background: var(--gradient-hero);"></div>
    <div class="decoration-grid"></div>
    <div class="glow-orb animate-pulse-glow" style="width: 300px; height: 300px; background: var(--color-secondary); opacity: 0.10; top: 10%; right: -5%;"></div>
    <div class="glow-orb animate-pulse-glow" style="width: 250px; height: 250px; background: var(--color-accent); opacity: 0.08; bottom: 10%; left: -5%; animation-delay: 2s;"></div>

    <div class="container-main" style="position: relative; z-index: 10; text-align: center;">

      <!-- Badge -->
      <div class="section-tag section-tag-purple animate-fade-up" style="margin-bottom: 1.5rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Perfil Profesional
      </div>

      <h1 class="hero-title animate-fade-up delay-100" style="margin-bottom: 1.25rem; font-size: clamp(2rem, 6vw, 4rem);">
        Mi Trayectoria<br/>
        <span class="gradient-text-purple">Profesional</span>
      </h1>

      <p class="hero-tagline animate-fade-up delay-200" style="max-width: 640px;">
        Soy un profesional apasionado por la intersección entre la tecnología, la gestión de proyectos y la estrategia empresarial. A lo largo de mi carrera, he desarrollado una sólida experiencia en la entrega de soluciones innovadoras y eficientes. Para conocer en detalle mi formación, experiencia y los proyectos en los que he participado, te invito a descargar mi CV completo.
      </p>

      <div class="animate-fade-up delay-300">
        <a
          href="/CV Esp Gabriel Lopez 2026.pdf"
          download="CV-Gabriel-Lopez.pdf"
          class="btn btn-purple"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          Descargar CV Completo (PDF)
        </a>
      </div>
    </div>
  </section>
</Layout>
