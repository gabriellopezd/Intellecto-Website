---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sobre Mí - Gabriel Lopez">
  <section class="container mx-auto px-6 py-20 min-h-[70vh] flex items-center">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-5xl md:text-6xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-600">
        Mi Trayectoria Profesional
      </h1>
      <p class="text-lg text-gray-300 mb-12">
        Soy un profesional apasionado por la intersección entre la tecnología, la gestión de proyectos y la estrategia empresarial. A lo largo de mi carrera, he desarrollado una sólida experiencia en la entrega de soluciones innovadoras y eficientes. Para conocer en detalle mi formación, experiencia y los proyectos en los que he participado, te invito a descargar mi CV completo.
      </p>
      <a 
        href="/CV Esp Gabriel Lopez 2026.pdf" 
        download="CV-Gabriel-Lopez.pdf"
        class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-bold py-4 px-10 rounded-full text-xl transition-transform transform hover:scale-105 shadow-lg"
      >
        Descargar CV Completo (PDF)
      </a>
    </div>
  </section>
</Layout>
